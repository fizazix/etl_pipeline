APP_NAME=IngestionPipeline
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ingestion
DB_USERNAME=ingestion
DB_PASSWORD=secret

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

SOURCE_API_URL=http://source-api:8080/records
INGESTION_PIPELINE_NAME=default
INGESTION_MAX_RETRIES=5
INGESTION_BACKOFF_BASE_MS=100
INGESTION_BACKOFF_MAX_MS=2000
INGESTION_REQUEST_TIMEOUT=10
